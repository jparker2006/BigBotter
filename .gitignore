# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# generated local season assets
/data/casts/*.json
/public/generated/portraits/**
!/public/generated/portraits/.gitkeep

# saved season runs + debug logs (local persistence, M8)
/runs/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
